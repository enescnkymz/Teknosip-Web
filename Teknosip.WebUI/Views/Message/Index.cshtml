@using Teknosip.WebUI.Services
@using Teknosip.Application.Features.Messages.Models
@model PaginatedMessagesDto

@{
    ViewData["Title"] = "Gelen Kutusu";
    Layout = ViewBag.LayoutPath ?? "~/Views/Shared/_Layout.cshtml";
}

<h4 class="fw-bold py-3 mb-4">
    <span class="text-muted fw-light">İletişim /</span> Mesajlar
</h4>

<div class="card shadow-sm border-0">
    <div class="card-header d-flex justify-content-between align-items-center bg-white border-bottom pb-3">
        <h5 class="mb-0 fw-semibold text-dark"><i class="bx bx-archive-in text-primary me-2"></i>Gelen Kutusu</h5>
        <button onclick="markAllMessagesAsRead()" class="btn btn-sm btn-primary">
            <i class="bx bx-check-double me-1"></i> Tümünü Okundu İşaretle
        </button>
    </div>

    <div class="card-body p-0">
        <div class="list-group list-group-flush">

            @if (Model.Messages != null && Model.Messages.Any())
            {
                @foreach (var item in Model.Messages)
                {
                    string bgClass = item.IsRead ? "bg-white" : "bg-lighter message-item-unread";
                    string avatarUrl = string.IsNullOrEmpty(item.SenderImageUrl)
                                       ? "/images/profiles/default.webp"
                                       : item.SenderImageUrl;

                    <div class="list-group-item list-group-item-action d-flex align-items-center p-3 @bgClass" style="border-bottom: 1px solid #f0f2f4; transition: all 0.2s ease-in-out;">

                        <div class="flex-shrink-0 me-3">
                            <img src="@avatarUrl" alt="@item.SenderName" class="rounded-circle shadow-sm" style="width: 48px; height: 48px; object-fit: cover;">
                        </div>

                        <div class="flex-grow-1 overflow-hidden pe-3">
                            <h6 class="mb-1 fw-bold text-truncate" style="color: #435971; font-size: 0.95rem;">@item.SenderName</h6>
                            <p class="mb-0 text-truncate" style="font-size: 0.875rem; color: #697a8d;">
                                @item.MessageContent
                            </p>
                        </div>

                        <div class="flex-shrink-0 d-flex align-items-center gap-3">

                            <small class="text-muted text-nowrap">
                                <i class="bx bx-time-five me-1"></i>@DateTimeExtensions.ToTimeAgo(item.CreatedAt)
                            </small>

                            <button type="button" onclick="toggleReadStatus(@item.Id, this)" class="btn btn-sm btn-icon btn-text-secondary rounded-circle border-0 bg-transparent p-0" style="width: auto; height: auto;">
                                <i class="bx @(item.IsRead ? "bx-envelope" : "bx-envelope-open") fs-5"
                                   style="color: #a1acb8;"
                                   title="@(item.IsRead ? "Okunmadı İşaretle" : "Okundu İşaretle")"></i>
                            </button>

                            <span class="unread-message-dot rounded-circle flex-shrink-0"
                                  style="width: 8px; height: 8px; background-color: #696cff; @(item.IsRead ? "display:none;" : "")">
                            </span>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center p-5">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 80px; height: 80px; background-color: rgba(105,108,255,.08);">
                        <i class="bx bx-envelope" style="font-size: 2.5rem; color:#696cff;"></i>
                    </div>
                    <h5 class="fw-semibold text-dark mb-1">Gelen kutunuz boş</h5>
                    <p class="text-muted mb-0">Henüz hiç mesajınız bulunmuyor.</p>
                </div>
            }

        </div>
    </div>
</div>


@if (Model.TotalPages > 1)
{
    <div class="card-footer d-flex justify-content-center bg-white border-top pb-0 pt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm">

                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">
                        <i class="tf-icon bx bx-chevrons-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">
                        <i class="tf-icon bx bx-chevrons-right"></i>
                    </a>
                </li>

            </ul>
        </nav>
    </div>
}


@section Scripts{

    <script>


        function toggleReadStatus(messageId, element) {
            var $item = $(element).closest('.list-group-item');
            var isCurrentlyRead = !$item.hasClass('message-item-unread');
            var willBeRead = !isCurrentlyRead;

            $.ajax({
                url: '/Message/ChangeReadStatus',
                type: 'POST',
                data: { id: messageId, markAsRead: willBeRead },
                success: function (data) {
                    if (data.success) {
                        var $icon = $(element).find('i');
                        var $dot = $item.find('.unread-message-dot');

                        var $mainBadge = $('#unread-message-badge-main');
                        var $headerBadge = $('#unread-message-badge-header');

                        // Sayıyı güvenle al (Eğer boşsa veya hatalıysa 0 kabul et)
                        var currentText = $mainBadge.text().replace('Yeni', '').trim();
                        var currentCount = parseInt(currentText) || 0;

                        if (willBeRead) {
                            // OKUNDU YAPILIYOR
                            $item.removeClass('message-item-unread bg-lighter').css('background', 'transparent');
                            $dot.hide();
                            $icon.removeClass('bx-envelope-open').addClass('bx-envelope').attr('title', 'Okunmadı İşaretle');
                            currentCount = Math.max(0, currentCount - 1);
                        } else {
                            // OKUNMADI YAPILIYOR
                            $item.addClass('message-item-unread bg-lighter').css('background', '');
                            $dot.show();
                            $icon.removeClass('bx-envelope').addClass('bx-envelope-open').attr('title', 'Okundu İşaretle');
                            currentCount++;
                        }

                        // Rozetleri yeni sayı ile güncelle
                        $mainBadge.text(currentCount);
                        $headerBadge.text(currentCount + ' Yeni');

                        // Sayı 0'dan büyükse göster, değilse gizle
                        if (currentCount > 0) {
                            $mainBadge.show();
                            $headerBadge.show();
                        } else {
                            $mainBadge.hide();
                            $headerBadge.hide();
                        }
                    }
                }
            });
        }


    </script>


}
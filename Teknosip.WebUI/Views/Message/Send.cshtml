@model Teknosip.Application.Features.Messages.Commands.SendMessage.SendMessageCommand

@{
    ViewData["Title"] = "Yeni Mesaj Gönder";
    Layout = ViewBag.LayoutPath ?? "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />


<h4 class="fw-bold py-3 mb-4">
    <span class="text-muted fw-light">İletişim /</span> Yeni Mesaj
</h4>


@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i class="bx bx-check-circle fs-5"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>

        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-8 col-lg-6 me-auto">
        <div class="card shadow-sm border-0 mb-4">

            <div class="card-header d-flex justify-content-between align-items-center border-bottom bg-white pb-3">
                <h5 class="mb-0 fw-semibold text-dark"><i class="bx bx-paper-plane text-primary me-2"></i>Mesaj Gönder</h5>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bx bx-arrow-back me-1"></i> Gelen Kutusu
                </a>
            </div>

            <div class="card-body pt-4">
                <form asp-action="Send" method="post">

                    <div class="mb-4">
                        <label asp-for="ReceiverId" class="form-label fw-medium">Kime</label>
                        <select asp-for="ReceiverId" id="receiverSelect" class="form-select" required>
                        </select>
                        <span asp-validation-for="ReceiverId" class="text-danger small mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Content" class="form-label fw-medium">Mesajınız</label>
                        <textarea asp-for="Content" class="form-control" rows="6" placeholder="Mesajınızı buraya yazın..." required></textarea>
                        <span asp-validation-for="Content" class="text-danger small mt-1"></span>
                    </div>

                    <div class="text-end border-top pt-3">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bx bx-send me-2"></i> Gönder
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6 mb-4">
        <div class="card bg-label-primary shadow-none border-0 h-100 alert alert-dismissible fade show mb-0" role="alert">

            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="top: 15px; right: 15px; position: absolute; z-index: 2;"></button>

            <div class="card-body d-flex flex-column justify-content-center position-relative">
                <div class="text-center mb-3">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 60px; height: 60px; background-color: rgba(105,108,255,.12);">
                        <i class="bx bx-paper-plane text-primary fs-2"></i>
                    </div>
                    <h5 class="fw-bold text-primary mb-1">Nasıl Çalışır?</h5>
                </div>

                <ul class="text-muted ps-3 mt-2" style="font-size: 0.9rem; line-height: 1.6;">
                    <li class="mb-2">Arama kutusuna en az <strong>2 harf</strong> yazarak sistemdeki akademisyen, öğrenci veya şirketleri bulabilirsiniz.</li>
                    <li class="mb-2">Yanlış kişiyi seçerseniz, ismin yanındaki <strong>'x'</strong> butonuna tıklayarak seçimi temizleyebilirsiniz.</li>
                    <li>Gönderdiğiniz mesaj, karşı tarafın gelen kutusuna anında <strong>okunmadı</strong> olarak düşer.</li>
                </ul>
            </div>
        </div>
    </div>



</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#receiverSelect').select2({
                placeholder: "Kişi arayın (En az 2 harf)...",
                allowClear: true,
                minimumInputLength: 2,
                language: {
                    inputTooShort: function () { return "Aramak için en az 2 harf girin..."; },
                    searching: function () { return "Aranıyor..."; },
                    noResults: function () { return "Kullanıcı bulunamadı."; }
                },
                ajax: {
                    url: '/Message/SearchUsers',
                    dataType: 'json',
                    delay: 250, // Kullanıcı yazarken sunucuyu yormamak için bekleme süresi
                    data: function (params) {
                        return {
                            term: params.term // Controller'daki 'term' parametresine gönderilir
                        };
                    },
                    processResults: function (data) {
                        // Controller'dan gelen JSON verisini Select2'ye veriyoruz
                        return {
                            results: data.results
                        };
                    },
                    cache: true
                }
            });
        });
    </script>
}
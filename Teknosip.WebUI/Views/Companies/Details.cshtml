@using Teknosip.Application.Features.CompanyProfiles.Models
@model CompanyDetailDto

@{
    ViewData["Title"] = Model.CompanyName + " - Firma Detayı";
}

<style>
    .company-header-bg {
        background-color: #f3f5fa;
        padding: 40px 0;
        border-bottom: 1px solid #e1e6f1;
    }

    .profile-card {
        border-top: 4px solid #47b2e4;
        box-shadow: 0 0 30px rgba(55, 81, 126, 0.08);
    }

    .info-list li {
        margin-bottom: 15px;
        padding-bottom: 15px;
        border-bottom: 1px dashed #eee;
        display: flex;
        align-items: flex-start;
    }

        .info-list li:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

    .info-list i {
        font-size: 1.2rem;
        color: #47b2e4;
        margin-right: 12px;
        margin-top: 2px;
    }

    .info-title {
        font-weight: 600;
        color: #37517e;
        display: block;
        font-size: 0.9rem;
    }

    .info-value {
        color: #555;
        font-size: 0.95rem;
    }
</style>

<section class="company-header-bg">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1" style="color: #37517e;">@Model.CompanyName</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Ana Sayfa</a></li>
                    <li class="breadcrumb-item"><a href="/Companies" class="text-decoration-none">Firmalarımız</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Detay</li>
                </ol>
            </nav>
        </div>
       
    </div>
</section>

<section class="section py-5">
    <div class="container">
        <div class="row gy-5">

            <div class="col-lg-4">
                <div class="card profile-card border-0 rounded-4 p-4 text-center">
                    <div class="mb-4">
                        <img src="@(Model.ProfilePhoto ?? "/images/profiles/default.webp")"
                             class="img-fluid rounded-circle border shadow-sm p-1"
                             style="width: 160px; height: 160px; object-fit: cover;" alt="@Model.CompanyName Logo">
                    </div>

                    <h4 class="fw-bold mb-1" style="color: #37517e;">@Model.CompanyName</h4>
                    <p class="text-muted small mb-4">@Model.Sector - @Model.City</p>

                    @if (!string.IsNullOrEmpty(Model.Website))
                    {
                        <a href="@Model.Website" target="_blank" class="btn btn-primary rounded-pill w-100 mb-3" style="background: #47b2e4; border: none;">
                            <i class="bi bi-globe me-2"></i> Web Sitesini Ziyaret Et
                        </a>
                    }

                    <ul class="list-unstyled text-start info-list mt-4">
                        <li>
                            <i class="bi bi-envelope"></i>
                            <div>
                                <span class="info-title">E-Posta Adresi</span>
                                <span class="info-value">@(Model.Email ?? "Belirtilmemiş")</span>
                            </div>
                        </li>
                        <li>
                            <i class="bi bi-telephone"></i>
                            <div>
                                <span class="info-title">Telefon Numarası</span>
                                <span class="info-value">@(Model.PhoneNumber ?? "Belirtilmemiş")</span>
                            </div>
                        </li>
                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <div>
                                <span class="info-title">Bulunduğu Şehir</span>
                                <span class="info-value">@(Model.City ?? "Belirtilmemiş")</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 h-100">

                    <h3 class="fw-bold mb-4" style="color: #37517e; border-bottom: 2px solid #f3f5fa; padding-bottom: 15px;">Firma Hakkında</h3>

                    <p class="text-muted mb-5" style="line-height: 1.8;">
                        @(string.IsNullOrEmpty(Model.About) ? "Bu firma henüz hakkında yazısı eklememiştir." : Model.About)
                    </p>

                    <h4 class="fw-bold mb-4" style="color: #37517e;">Kurumsal Bilgiler</h4>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <div class="bg-light rounded text-center me-3" style="width: 45px; height: 45px; line-height: 45px; color: #47b2e4;">
                                    <i class="bi bi-calendar3 fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1" style="color: #37517e;">Kuruluş Yılı</h6>
                                    <span class="text-muted">@(Model.FoundedYear?.ToString() ?? "Belirtilmemiş")</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <div class="bg-light rounded text-center me-3" style="width: 45px; height: 45px; line-height: 45px; color: #47b2e4;">
                                    <i class="bi bi-people fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1" style="color: #37517e;">Çalışan Sayısı</h6>
                                    <span class="text-muted">@(Model.EmployeeCount?.ToString() ?? "Belirtilmemiş") Kişi</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <div class="bg-light rounded text-center me-3" style="width: 45px; height: 45px; line-height: 45px; color: #47b2e4;">
                                    <i class="bi bi-file-earmark-text fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1" style="color: #37517e;">Vergi Numarası</h6>
                                    <span class="text-muted">@(string.IsNullOrEmpty(Model.TaxNumber) ? "Belirtilmemiş" : Model.TaxNumber)</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <div class="bg-light rounded text-center me-3" style="width: 45px; height: 45px; line-height: 45px; color: #47b2e4;">
                                    <i class="bi bi-clock-history fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1" style="color: #37517e;">Kayıt Tarihi</h6>
                                    <span class="text-muted">@Model.CreatedAt.ToString("dd MMMM yyyy")</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="d-flex align-items-start p-3 bg-light rounded border border-light">
                                <div class="text-center me-3" style="color: #47b2e4;">
                                    <i class="bi bi-geo-alt-fill fs-3"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1" style="color: #37517e;">Açık Adres</h6>
                                    <span class="text-muted">
                                        @(string.IsNullOrEmpty(Model.Address) ? "Adres bilgisi eklenmemiş." : Model.Address) <br />
                                        
                                    </span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
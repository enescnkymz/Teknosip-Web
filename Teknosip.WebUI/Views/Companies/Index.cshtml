@using Teknosip.Application.Features.CompanyProfiles.Models
@model IEnumerable<CompanySummaryDto>

@{
    ViewData["Title"] = "Firmalar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
   

    .btn-arsha-outline {
        color: #47b2e4;
        border: 1px solid #47b2e4;
        border-radius: 50px;
        padding: 6px 20px;
        transition: 0.3s;
        font-size: 0.9rem;
    }

        .btn-arsha-outline:hover {
            background: #47b2e4;
            color: #fff;
        }


    .company-card {
        transition: all 0.3s ease-in-out;
        border: 1px solid rgba(71, 178, 228, 0.1);
        cursor: pointer; /* Farenin el işaretine dönüşmesini sağlar */
    }

        .company-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 30px rgba(55, 81, 126, 0.15) !important;
            border-color: rgba(71, 178, 228, 0.5);
        }

    .company-icon {
        color: #47b2e4;
    }

</style>

<section id="companies-header" class="section pb-0" >
    <div class="container section-title" data-aos="fade-up">
        <h2>Kurumsal İş Ortaklarımız</h2>
        <p>Sistemimizde yer alan, sektörünün öncüsü onaylı firma ve şirketler.</p>
    </div>
</section>

<section id="companies-list" class="section pt-3">
    <div class="container" data-aos="fade-up" data-aos-delay="100">

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-building text-muted opacity-50" style="font-size: 4rem;"></i>
                <h5 class="mt-3 text-muted">Henüz onaylanmış bir firma bulunmuyor.</h5>
            </div>
        }
        else
        {
            <div class="row gy-4">
                @foreach (var company in Model)
                {
                    <div class="col-lg-4 col-md-6 d-flex align-items-stretch">
                        <div class="card w-100 shadow-sm rounded-4 overflow-hidden company-card bg-white position-relative">
                            <div class="card-body text-center p-4 d-flex flex-column">

                                <div class="mb-3 mt-2">
                                    <img src="@(company.ProfilePhoto ?? "/images/profiles/default-company.webp")"
                                         class="rounded-circle border shadow-sm p-1"
                                         style="width: 110px; height: 110px; object-fit: cover;" alt="@company.CompanyName Logo">
                                </div>

                                <h4 class="fw-bold" style="color: #37517e;">
                                    <a asp-controller="Companies" asp-action="Details" asp-route-id="@company.AppUserId" class="text-decoration-none stretched-link" style="color: inherit;">
                                        @company.CompanyName
                                    </a>
                                </h4>

                                <p class="text-muted small mb-3 mt-1">
                                    <i class="bi bi-tag-fill company-icon me-1"></i> @(string.IsNullOrEmpty(company.Sector) ? "Sektör Belirtilmemiş" : company.Sector)
                                </p>

                                <div class="d-flex justify-content-center gap-3 mb-2 small fw-medium" style="color: #555;">
                                    <span>
                                        <i class="bi bi-geo-alt-fill company-icon me-1"></i> @company.City
                                    </span>

                                    @if (company.EmployeeCount != null && company.EmployeeCount > 0)
                                    {
                                        <span>
                                            <i class="bi bi-people-fill company-icon me-1"></i> @company.EmployeeCount Çalışan
                                        </span>
                                    }
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<body class="index-page">

    <partial name="Partials/_HeaderPartial" />

    <main class="main">


        @RenderBody()

    </main>

    <partial name="Partials/_FooterPartial" />

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <!-- Preloader -->
    <div id="preloader"></div>

    <!-- Vendor JS Files -->
    <script src="~/themes/arsha/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/themes/arsha/assets/vendor/aos/aos.js"></script>
    <script src="~/themes/arsha/assets/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="~/themes/arsha/assets/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="~/themes/arsha/assets/vendor/waypoints/noframework.waypoints.js"></script>
    <script src="~/themes/arsha/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
    <script src="~/themes/arsha/assets/vendor/isotope-layout/isotope.pkgd.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- Main JS File -->
    <script src="~/themes/arsha/assets/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        $(document).ready(function () {
            $("#newsletterForm").submit(function (e) {
                // 1. Sayfanın yenilenmesini kesinlikle durdur!
                e.preventDefault();

                var emailValue = $("#newsletterEmail").val();
                var messageBox = $("#newsletterMessage");

                // 2. Arka planda Controller'a veriyi gönder
                $.ajax({
                    type: "POST",
                    url: "/Newsletter/Subscribe",
                    data: { email: emailValue },
                    success: function (response) {
                        // Controller'dan dönen JSON'ı yakala ve ekrana bas
                        messageBox.show();
                        if (response.success) {
                            messageBox.removeClass("text-danger").addClass("text-success");
                            messageBox.text(response.message);
                            $("#newsletterEmail").val(""); // Başarılıysa kutuyu temizle
                        }

                        else {
                            messageBox.removeClass("text-success").addClass("text-danger");
                            messageBox.text(response.message);
                        }
                    },
                    error: function () {
                        messageBox.show().removeClass("text-success").addClass("text-danger");
                        messageBox.text("Sistemsel bir hata oluştu, lütfen daha sonra tekrar deneyiniz.");
                    }
                });
            });
        });
    </script>

</body>
</html>
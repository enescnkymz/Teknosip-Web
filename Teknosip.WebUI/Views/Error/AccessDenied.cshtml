@{
    ViewData["Title"] = "Yetkisiz Erişim";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Teknosip</title>
    <link rel="icon" type="image/png" href="~/images/site/teknosip-logo.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">

    <style>

        body {
            background-color: #f3f5fa;
            font-family: "Open Sans", sans-serif;
        }

        .error-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0px 0px 30px rgba(127, 137, 161, 0.25);
            padding: 3rem 2rem;
            text-align: center;
            max-width: 500px;
            width: 90%;
        }

        .error-title {
            color: #37517e;
        }

        .btn-arsha {
            background-color: #47b2e4;
            border-color: #47b2e4;
            border-radius: 50px;
            padding: 10px 30px;
            transition: 0.3s;
        }

            .btn-arsha:hover {
                background-color: #209dd8;
                border-color: #209dd8;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(71, 178, 228, 0.4);
            }
    </style>
</head>
<body class="d-flex justify-content-center align-items-center vh-100">

    <div class="error-card">
        <h2 class="fw-bold mb-3 error-title">Yetkisiz Erişim! 🔐</h2>
        <p class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">
            Oooops! Görünüşe göre bu sayfayı görüntülemek için gerekli izinlere sahip değilsiniz. Kendi alanınıza dönmek için aşağıdaki butonu kullanabilirsiniz.
        </p>

        <div class="mb-4">
            <i class="bx bx-error-circle text-danger" style="font-size: 7rem; opacity: 0.8;"></i>
        </div>

        <a href="/" class="btn btn-arsha text-white fw-medium">
            <i class="bx bx-home-alt me-1 align-middle"></i> <span class="align-middle">Ana Sayfaya Dön</span>
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
@{
    ViewData["Title"] = "Sayfa Bulunamadı";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="~/images/site/teknosip-logo.png" />
    <title>@ViewData["Title"] - Teknosip</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f3f5fa; 
            font-family: "Open Sans", sans-serif;
        }

        .error-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0px 0px 30px rgba(127, 137, 161, 0.25);
            padding: 3.5rem 2rem;
            text-align: center;
            max-width: 550px;
            width: 90%;
        }

        .error-code {
            font-size: 8rem;
            font-weight: 800;
            color: #37517e;
            line-height: 1;
            margin-bottom: 0;
            text-shadow: 4px 4px 0px rgba(71, 178, 228, 0.2);
        }

        .error-title {
            color: #37517e;
            font-weight: 700;
            font-size: 1.75rem;
        }

        .btn-arsha {
            background-color: #47b2e4;
            border-color: #47b2e4;
            border-radius: 50px;
            padding: 10px 30px;
            transition: 0.3s;
        }

            .btn-arsha:hover {
                background-color: #209dd8;
                border-color: #209dd8;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(71, 178, 228, 0.4);
            }
    </style>
</head>
<body class="d-flex justify-content-center align-items-center vh-100">

    <div class="error-card">
        <h1 class="error-code">404</h1>

        <h2 class="error-title mb-3 mt-2">Oooops! Sayfa Kayıp... 🕵️‍♂️</h2>

        <p class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">
            Görünüşe göre aradığınız sayfa ortada yok. URL'yi yanlış yazmış olabilirsiniz.
        </p>

        <div class="mb-4 text-secondary opacity-50">
            <i class="bx bx-ghost" style="font-size: 5rem;"></i>
        </div>

        <a href="/" class="btn btn-arsha text-white fw-medium mt-2">
            <i class="bx bx-home-alt me-1 align-middle"></i> <span class="align-middle">Beni Ana Sayfaya Götür</span>
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
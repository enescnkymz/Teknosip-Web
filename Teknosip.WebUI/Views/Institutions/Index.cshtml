@using Teknosip.Application.Features.InstitutionProfile.Models
@model IEnumerable<PublicInstitutionDto>

@{
    ViewData["Title"] = "Kurumlar";
}

<style>
    .company-header-bg {
        background-color: #f3f5fa;
        padding: 120px 0 40px 0;
        border-bottom: 1px solid #e1e6f1;
    }

    .institution-card {
        border: 1px solid rgba(71, 178, 228, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .institution-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(55, 81, 126, 0.1) !important;
        }
    
    .website-link {
        position: relative;
        z-index: 3;
    }
</style>

<section id="companies-header" class="section pb-0">
    <div class="container section-title" data-aos="fade-up">
        <h2>Değerli Paydaşlarımız</h2>
        <p>Ekosistemimize değer katan, onaylı kamu kurumları, STK'lar ve teknoloji merkezleri.</p>
    </div>
</section>



<section class="section py-5 bg-white">
    <div class="container" data-aos="fade-up">

        

        <div class="row gy-4">
            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5">
                    <h5 class="text-muted">Şu an sistemde onaylı bir kurum bulunmamaktadır.</h5>
                </div>
            }
            else
            {
                foreach (var item in Model)
                {
                    <div class="col-lg-6" data-aos="zoom-in" data-aos-delay="100">
                        <div class="institution-card d-flex align-items-start rounded-4 shadow-sm bg-white p-4 h-100 position-relative">

                            <div class="pic flex-shrink-0 me-4">
                                <img src="@(item.ProfilePhoto ?? "/images/profiles/default-company.webp")"
                                     class="img-fluid rounded-circle border shadow-sm p-2"
                                     style="width: 110px; height: 110px; object-fit: contain; background-color: #fff;"
                                     alt="@item.InstitutionName">
                            </div>

                            <div class="member-info flex-grow-1">

                                <h4 class="fw-bold mb-1" style="font-size: 1.25rem;">
                                    <a asp-controller="Institutions" asp-action="Details" asp-route-id="@item.AppUserId" class="text-decoration-none stretched-link" style="color: #37517e;">
                                        @item.InstitutionName
                                    </a>
                                </h4>

                                <div class="mb-2 text-muted fw-medium" style="font-size: 0.9rem;">
                                    <i class="bi bi-geo-alt-fill me-1 text-primary"></i> @item.City
                                </div>

                                <p class="text-muted small mb-3" style="line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    @(string.IsNullOrEmpty(item.About) ? "Bu kurum henüz hakkında bilgisi girmemiştir." : item.About)
                                </p>

                                @if (!string.IsNullOrEmpty(item.Website))
                                {
                                    <a href="@(item.Website.StartsWith("http") ? item.Website : $"https://{item.Website}")" target="_blank" class="website-link badge bg-light text-primary border px-3 py-2 text-decoration-none rounded-pill">
                                        <i class="bi bi-link-45deg me-1"></i> Web Sitesini Ziyaret Et
                                    </a>
                                }
                            </div>

                        </div>
                    </div>
                }
            }
        </div>

    </div>
</section>
@using Teknosip.WebUI.Areas.Student.Models
@model StudentProfileEditVM

@{
    ViewData["Title"] = "Profil Ayarları";
    Layout = "~/Areas/Student/Views/Shared/_Layout.cshtml";
}

<h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Hesap Ayarları /</span> Öğrenci Profili</h4>

<div class="row">
    <div class="col-md-12">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bx bx-check-circle me-1"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card mb-4">
            <h5 class="card-header">Öğrenci Profil Detayları</h5>

            <form asp-area="Student" asp-controller="Profile" asp-action="Index" method="POST" enctype="multipart/form-data">

                <div class="card-body pb-0">
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold"></div>
                </div>

                <div class="card-body">
                    <div class="d-flex align-items-start align-items-sm-center gap-4">
                        <img src="@(Model.CurrentPhotoUrl ?? "/images/profiles/default.webp")"
                             alt="student-avatar" class="d-block rounded" height="100" width="100" id="uploadedAvatar" style="object-fit: cover;" />
                        <div class="button-wrapper">
                            <label for="upload" class="btn btn-primary me-2 mb-4" tabindex="0">
                                <span class="d-none d-sm-block">Yeni Fotoğraf Yükle</span>
                                <i class="bx bx-upload d-block d-sm-none"></i>
                                <input asp-for="NewProfilePhoto" type="file" id="upload" class="account-file-input" hidden accept="image/png, image/jpeg" />
                            </label>
                            <p class="text-muted mb-0">İzin verilen formatlar: JPG, PNG. Maksimum boyut 2MB</p>
                            <span asp-validation-for="NewProfilePhoto" class="text-danger d-block mt-1"></span>
                        </div>
                    </div>
                </div>
                <hr class="my-0" />

                <div class="card-body">
                    <div class="row">
                        <input type="hidden" asp-for="CurrentPhotoUrl" />

                        <div class="mb-3 col-md-6">
                            <label asp-for="FullName" class="form-label">Ad Soyad</label>
                            <input asp-for="FullName" class="form-control" type="text" placeholder="Ali Veli" autofocus />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3 col-md-6">
                            <label asp-for="Email" class="form-label">E-Posta Adresi</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="ornek@ogrenci.edu.tr" readonly />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3 col-md-6">
                            <label asp-for="PhoneNumber" class="form-label">Telefon Numarası</label>
                            <div class="input-group">
                                <span class="input-group-text text-muted">+90</span>
                                <input asp-for="PhoneNumber" class="form-control" type="text" placeholder="555 555 55 55" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3 col-md-6">
                            <label asp-for="StudentNumber" class="form-label">Öğrenci Numarası</label>
                            <input asp-for="StudentNumber" class="form-control" type="text" placeholder="2021123456" />
                            <span asp-validation-for="StudentNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3 col-md-6">
                            <label asp-for="University" class="form-label">Üniversite</label>
                            <select asp-for="University" class="form-select" required>
                                <option value="">Seçiniz...</option>
                                <option value="Kütahya Dumlupınar Üniversitesi">Kütahya Dumlupınar Üniversitesi</option>
                                <option value="Kütahya Sağlık Bilimleri Üniversitesi">Kütahya Sağlık Bilimleri Üniversitesi</option>
                            </select>
                            <span asp-validation-for="University" class="text-danger"></span>
                        </div>

                        <div class="mb-3 col-md-4">
                            <label asp-for="Department" class="form-label">Bölüm</label>
                            <input asp-for="Department" class="form-control" type="text" placeholder="Yazılım Mühendisliği" />
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>

                        <div class="mb-3 col-md-2">
                            <label asp-for="Grade" class="form-label">Sınıf</label>
                            <select asp-for="Grade" class="form-select">
                                <option value="0">Hazırlık</option>
                                <option value="1">1. Sınıf</option>
                                <option value="2">2. Sınıf</option>
                                <option value="3">3. Sınıf</option>
                                <option value="4">4. Sınıf</option>
                            </select>
                            <span asp-validation-for="Grade" class="text-danger"></span>
                        </div>

                        <div class="mb-3 col-md-12">
                            <label asp-for="About" class="form-label">Hakkımda</label>
                            <textarea asp-for="About" class="form-control" rows="4" placeholder="İlgi alanlarınız, bildiğiniz diller, hedefleriniz..."></textarea>
                            <span asp-validation-for="About" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h5 class="card-title mb-3 text-primary">Şifre Değiştirme <small class="text-muted fs-6">(İsteğe Bağlı)</small></h5>

                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label asp-for="CurrentPassword" class="form-label">Mevcut Şifre</label>
                            <input asp-for="CurrentPassword" class="form-control" type="password" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>
                        <div class="mb-3 col-md-4">
                            <label asp-for="NewPassword" class="form-label">Yeni Şifre</label>
                            <input asp-for="NewPassword" class="form-control" type="password" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>
                        <div class="mb-3 col-md-4">
                            <label asp-for="ConfirmNewPassword" class="form-label">Yeni Şifre (Tekrar)</label>
                            <input asp-for="ConfirmNewPassword" class="form-control" type="password" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary me-2">Değişiklikleri Kaydet</button>
                        <button type="reset" class="btn btn-outline-secondary">Vazgeç</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('upload').addEventListener('change', function (event) {
            var reader = new FileReader();
            reader.onload = function () {
                var output = document.getElementById('uploadedAvatar');
                output.src = reader.result;
            }
            reader.readAsDataURL(event.target.files[0]);
        });
    </script>
}